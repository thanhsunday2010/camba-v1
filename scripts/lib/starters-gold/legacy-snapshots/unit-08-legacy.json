  "grammarReference": [
    {
      "structure": "Imperatives: Open, Close, Sit down",
      "explanation": "Use the verb alone to give a command or instruction. No subject (you) is needed.",
      "examples": [
        "Open your book.",
        "Close the door.",
        "Sit down, please."
      ],
      "commonMistakes": [
        "You open the book (×) → Open your book (✓)",
        "Sits down (×) → Sit down (✓)"
      ],
      "programLevel": "starters",
      "topic": "school"
    },
    {
      "structure": "Have got: I've got a pen",
      "explanation": "Use have got to say you possess something. I've got = I have got. Has she got? asks about another person.",
      "examples": [
        "I've got a pen.",
        "She's got a new bag.",
        "Have you got a ruler?"
      ],
      "commonMistakes": [
        "I have a got pen (×) → I've got a pen (✓)",
        "She have got a book (×) → She's got a book (✓)"
      ],
      "programLevel": "starters",
      "topic": "school"
    },
    {
      "structure": "Present simple: work, teach",
      "explanation": "Use work to talk about a job. Use teach for a teacher's job. Add -s with he/she: He works. She teaches.",
      "examples": [
        "My father works.",
        "She teaches English.",
        "The farmer works on a farm."
      ],
      "commonMistakes": [
        "He work in a school (×) → He works in a school (✓)",
        "She teachs English (×) → She teaches English (✓)"
      ],
      "programLevel": "starters",
      "topic": "school"
    }
  ],
