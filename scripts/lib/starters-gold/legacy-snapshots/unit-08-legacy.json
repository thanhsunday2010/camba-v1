  "unit": {
    "learningObjectives": [
      "Name classroom objects and school people using Starters vocabulary.",
      "Follow and give simple classroom commands using imperatives.",
      "Use have got to talk about things you have at school.",
      "Use work and teach in present simple sentences about jobs.",
      "Read short texts to label classroom objects and listen to classroom commands."
    ],
    "grammarFocus": [
      "Imperatives: Open, Close, Sit down",
      "Have got: I've got a pen",
      "Present simple: work, teach"
    ],
    "readingSkillFocus": "Label Classroom Objects",
    "listeningSkillFocus": "Understand Classroom Commands"
  },
