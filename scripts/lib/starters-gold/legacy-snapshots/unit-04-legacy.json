  "grammarReference": [
    {
      "structure": "Demonstratives: this, that",
      "explanation": "Use this for one thing near you. Use that for one thing far from you.",
      "examples": [
        "This is a cat.",
        "That is a tiger.",
        "This is my dog."
      ],
      "commonMistakes": [
        "This is a cat (far away) (×) → That is a cat. (✓)",
        "That is my dog (in your hand) (×) → This is my dog. (✓)"
      ],
      "programLevel": "starters",
      "topic": "animals"
    },
    {
      "structure": "Plural nouns: regular -s",
      "explanation": "Add -s to most nouns to make the plural: one cat → two cats.",
      "examples": [
        "one dog, three dogs",
        "a bird, many birds",
        "one fish, two fish"
      ],
      "commonMistakes": [
        "two cat (×) → two cats (✓)",
        "three dog (×) → three dogs (✓)"
      ],
      "programLevel": "starters",
      "topic": "animals"
    },
    {
      "structure": "This is / That is + noun",
      "explanation": "Use This is or That is before a singular animal name to identify it.",
      "examples": [
        "This is a monkey.",
        "That is an elephant."
      ],
      "commonMistakes": [
        "This a monkey (×) → This is a monkey. (✓)",
        "That are a bear (×) → That is a bear. (✓)"
      ],
      "programLevel": "starters",
      "topic": "animals"
    }
  ],
