  "unit": {
    "learningObjectives": [
      "Name common sports and leisure activities using Starters vocabulary.",
      "Use can to talk about what you are able to do.",
      "Use play and go with sports and activities correctly.",
      "Match activities to pictures in short texts.",
      "Listen and identify sports, games and actions.",
      "Talk about what you can do and what games you play."
    ],
    "grammarFocus": [
      "Can for ability: I can swim",
      "Present simple: play, go"
    ],
    "readingSkillFocus": "Match Activities to Pictures",
    "listeningSkillFocus": "Identify Sports and Actions"
  },
