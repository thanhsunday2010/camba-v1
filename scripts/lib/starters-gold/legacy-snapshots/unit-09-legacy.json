  "grammarReference": [
    {
      "structure": "Can for ability: I can swim",
      "explanation": "Use can + verb to say what you are able to do. Can does not change with he, she, it.",
      "examples": [
        "I can swim.",
        "She can run.",
        "We can play football."
      ],
      "commonMistakes": [
        "I can swims (×) → I can swim (✓)",
        "He cans run (×) → He can run (✓)"
      ],
      "programLevel": "starters",
      "topic": "sports-and-leisure"
    },
    {
      "structure": "Present simple: play, go",
      "explanation": "Use play with ball games and games (play football, play tennis). Use go with -ing activities (go swimming). At Starters, play is most common.",
      "examples": [
        "I play football.",
        "They play a game.",
        "We play tennis."
      ],
      "commonMistakes": [
        "I go football (×) → I play football (✓)",
        "play swim (×) → go swimming / can swim (✓)"
      ],
      "programLevel": "starters",
      "topic": "sports-and-leisure"
    }
  ],
