  "grammarReference": [
    {
      "structure": "Question words: where, what",
      "explanation": "Use where to ask about place. Use what to ask about things or to identify something.",
      "examples": [
        "Where is the shop?",
        "What is this? — It is a bus.",
        "Where is your house?"
      ],
      "commonMistakes": [
        "Where is a car? (×) when asking identity → What is this? (✓)",
        "What is the park? (×) when asking place → Where is the park? (✓)"
      ],
      "programLevel": "starters",
      "topic": "transport-and-places"
    },
    {
      "structure": "Prepositions: next to, behind, in front of",
      "explanation": "Next to means beside. Behind means at the back. In front of means before something, facing it.",
      "examples": [
        "The shop is next to the park.",
        "The bus is behind the car.",
        "The tree is in front of the house."
      ],
      "commonMistakes": [
        "in front the house (×) → in front of the house (✓)",
        "next the shop (×) → next to the shop (✓)"
      ],
      "programLevel": "starters",
      "topic": "transport-and-places"
    }
  ],
