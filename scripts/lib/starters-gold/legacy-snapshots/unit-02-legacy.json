  "grammarReference": [
    {
      "structure": "Numbers 1–20",
      "explanation": "Use numbers to count people, things and to say age. Numbers one to twenty are core at Starters level.",
      "examples": [
        "I am seven.",
        "There are three cats.",
        "She is ten years old."
      ],
      "commonMistakes": [
        "I have seven year (×) → I am seven years old (✓)",
        "three cat (×) → three cats (✓)"
      ],
      "programLevel": "starters",
      "topic": "numbers-and-time"
    },
    {
      "structure": "Question words: how many, how old",
      "explanation": "Use how many to ask about quantity (countable things). Use how old to ask about age.",
      "examples": [
        "How many books? — Three books.",
        "How old are you? — I am eight."
      ],
      "commonMistakes": [
        "How many years you? (×) → How old are you? (✓)",
        "How old books? (×) → How many books? (✓)"
      ],
      "programLevel": "starters",
      "topic": "numbers-and-time"
    },
    {
      "structure": "Days and months (recognition)",
      "explanation": "Recognise days of the week and months. Use today for the current day. Birthday often includes a day or month.",
      "examples": [
        "Today is Monday.",
        "My birthday is on Tuesday.",
        "January is a month."
      ],
      "commonMistakes": [
        "Today is Monday? (statement) → Today is Monday. (✓)",
        "on Tuesday birthday (×) → My birthday is on Tuesday. (✓)"
      ],
      "programLevel": "starters",
      "topic": "numbers-and-time"
    }
  ],
