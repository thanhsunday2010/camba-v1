  "unit": {
    "learningObjectives": [
      "Recognise and use numbers 1–20 in familiar contexts.",
      "Ask and answer how old and how many questions.",
      "Name days of the week and use today correctly.",
      "Tell time using o'clock at Starters level.",
      "Talk about birthdays with numbers and days."
    ],
    "grammarFocus": [
      "Numbers 1–20",
      "Question words: how many, how old",
      "Days and months (recognition)"
    ],
    "readingSkillFocus": "Recognise Numbers and Days",
    "listeningSkillFocus": "Extract Ages and Numbers"
  },
