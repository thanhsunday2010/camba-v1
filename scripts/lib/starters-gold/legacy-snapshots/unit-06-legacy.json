  "unit": {
    "learningObjectives": [
      "Name common food and drink items using Starters vocabulary.",
      "Use like, eat and drink in present simple sentences.",
      "Say what you do not like using don't like.",
      "Read short sentences about food and choose matching pictures.",
      "Listen and identify food and drink items in short dialogues."
    ],
    "grammarFocus": [
      "Present simple: like, eat, drink",
      "Negation: I don't like"
    ],
    "readingSkillFocus": "Read Short Sentences with Pictures",
    "listeningSkillFocus": "Identify Food and Drink Items"
  },
