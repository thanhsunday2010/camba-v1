  "grammarReference": [
    {
      "structure": "Present simple: like, eat, drink",
      "explanation": "Use like for food you enjoy. Use eat for food and drink for liquids. Add -s with he, she, it: He likes rice.",
      "examples": [
        "I like apples.",
        "She eats an egg.",
        "He drinks milk."
      ],
      "commonMistakes": [
        "He like rice (×) → He likes rice (✓)",
        "I drink chicken (×) → I eat chicken (✓)"
      ],
      "programLevel": "starters",
      "topic": "food-and-drink"
    },
    {
      "structure": "Negation: I don't like",
      "explanation": "Use don't like to say you do not enjoy something. Don't = do not.",
      "examples": [
        "I don't like fish.",
        "She doesn't like milk.",
        "We don't like eggs."
      ],
      "commonMistakes": [
        "I not like fish (×) → I don't like fish (✓)",
        "I don't likes rice (×) → I don't like rice (✓)"
      ],
      "programLevel": "starters",
      "topic": "food-and-drink"
    }
  ],
