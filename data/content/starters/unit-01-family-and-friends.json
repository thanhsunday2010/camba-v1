  "grammarReference": [
    {
      "structure": "Verb be: am, is, are",
      "explanation": "Use am with I; is with he, she, it and singular nouns; are with you, we, they and plural nouns.",
      "examples": ["I am Mai.", "He is my brother.", "They are my friends."],
      "commonMistakes": ["I is happy (×) → I am happy (✓)", "She are my sister (×) → She is my sister (✓)"],
      "programLevel": "starters",
      "topic": "family-and-friends"
    },
    {
      "structure": "Possessive adjectives: my, your, his, her",
      "explanation": "Possessive adjectives come before a noun to show who something belongs to.",
      "examples": ["my father", "your friend", "his sister", "her mother"],
      "commonMistakes": ["he mother (×) → his mother (✓)", "she friend (×) → her friend (✓)"],
      "programLevel": "starters",
      "topic": "family-and-friends"
    },
    {
      "structure": "Question word: who",
      "explanation": "Use who to ask about a person.",
      "examples": ["Who is he?", "Who is your friend?"],
      "commonMistakes": ["What is he? (when asking identity) → Who is he? (✓)"],
      "programLevel": "starters",
      "topic": "family-and-friends"
    }
  ],
