  "unit": {
    "learningObjectives": [
      "Name family members and friends using core Starters vocabulary.",
      "Use verb be (am, is, are) to describe people.",
      "Use possessive adjectives my, your, his, her correctly.",
      "Answer who-questions about people in pictures and short texts.",
      "Introduce yourself and one family member in words and short phrases."
    ],
    "grammarFocus": [
      "Verb be: am, is, are",
      "Possessive adjectives: my, your, his, her",
      "Question word: who"
    ],
    "readingSkillFocus": "Match Words to Pictures",
    "listeningSkillFocus": "Identify Names and People"
  },
