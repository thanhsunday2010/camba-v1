  "grammarReference": [
    {
      "structure": "Adjective + noun order: a red shirt",
      "explanation": "In English, the colour adjective comes before the noun: a red shirt, not a shirt red.",
      "examples": [
        "a blue dress",
        "green shoes",
        "a yellow hat"
      ],
      "commonMistakes": [
        "a shirt red (×) → a red shirt (✓)",
        "dress blue a (×) → a blue dress (✓)"
      ],
      "programLevel": "starters",
      "topic": "colours-and-clothes"
    },
    {
      "structure": "Verb be for description",
      "explanation": "Use is or are with a colour adjective to describe what something looks like.",
      "examples": [
        "The shirt is red.",
        "The shoes are blue.",
        "Her dress is green."
      ],
      "commonMistakes": [
        "The shirt red is (×) → The shirt is red. (✓)",
        "The shoes is blue (×) → The shoes are blue. (✓)"
      ],
      "programLevel": "starters",
      "topic": "colours-and-clothes"
    },
    {
      "structure": "Question word: what colour",
      "explanation": "Use What colour is…? to ask about the colour of one thing.",
      "examples": [
        "What colour is your shirt?",
        "What colour are your shoes?"
      ],
      "commonMistakes": [
        "What is colour your shirt? (×) → What colour is your shirt? (✓)"
      ],
      "programLevel": "starters",
      "topic": "colours-and-clothes"
    }
  ],
