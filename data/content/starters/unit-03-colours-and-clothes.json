  "unit": {
    "learningObjectives": [
      "Name four basic colours and common clothes items at Starters level.",
      "Use adjective + noun order to describe clothes: a red shirt.",
      "Use verb be to describe colour: The dress is blue.",
      "Match colours to objects in pictures and short texts.",
      "Follow listen-and-colour instructions with colour and clothes words."
    ],
    "grammarFocus": [
      "Adjective + noun order: a red shirt",
      "Verb be for description",
      "Question word: what colour"
    ],
    "readingSkillFocus": "Match Colours and Objects",
    "listeningSkillFocus": "Listen and Colour"
  },
