  "unit": {
    "learningObjectives": [
      "Name furniture and rooms in a home using Starters vocabulary.",
      "Use there is and there are to describe a room.",
      "Use prepositions in, on and under to say where things are.",
      "Find objects in a picture scene when reading short texts.",
      "Follow simple instructions about objects in a room."
    ],
    "grammarFocus": [
      "There is / There are",
      "Prepositions of place: in, on, under"
    ],
    "readingSkillFocus": "Find Objects in a Scene",
    "listeningSkillFocus": "Follow Simple Instructions"
  },
