  "grammarReference": [
    {
      "structure": "There is / There are",
      "explanation": "Use there is with one thing (singular). Use there are with two or more things (plural).",
      "examples": [
        "There is a bed.",
        "There are two chairs.",
        "There is a lamp on the table."
      ],
      "commonMistakes": [
        "There are a chair (×) → There is a chair (✓)",
        "There is two windows (×) → There are two windows (✓)"
      ],
      "programLevel": "starters",
      "topic": "the-home"
    },
    {
      "structure": "Prepositions of place: in, on, under",
      "explanation": "Use in for inside a room or container. Use on for on top of a surface. Use under for below something.",
      "examples": [
        "Mum is in the kitchen.",
        "The cup is on the table.",
        "The cat is under the chair."
      ],
      "commonMistakes": [
        "on the kitchen (×) → in the kitchen (✓)",
        "under the table the book (×) → The book is under the table (✓)"
      ],
      "programLevel": "starters",
      "topic": "the-home"
    }
  ],
