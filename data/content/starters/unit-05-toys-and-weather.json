  "grammarReference": [
    {
      "structure": "It's + weather adjective: It's sunny",
      "explanation": "Use It's (It is) plus a weather adjective to describe the weather.",
      "examples": [
        "It's sunny.",
        "It's rainy.",
        "It's windy today."
      ],
      "commonMistakes": [
        "It sunny is (×) → It's sunny. (✓)",
        "It's sun (×) → It's sunny. (✓)"
      ],
      "programLevel": "starters",
      "topic": "toys-and-weather"
    },
    {
      "structure": "Plural nouns: two kites",
      "explanation": "Add -s to most nouns after numbers greater than one: two kites, three balloons.",
      "examples": [
        "one doll, two dolls",
        "a robot, many robots",
        "one kite, five kites"
      ],
      "commonMistakes": [
        "two kite (×) → two kites (✓)",
        "three balloon (×) → three balloons (✓)"
      ],
      "programLevel": "starters",
      "topic": "toys-and-weather"
    },
    {
      "structure": "Demonstratives: these, those",
      "explanation": "Use these for things near you (plural). Use those for things far from you (plural).",
      "examples": [
        "These are my toys.",
        "Those are kites in the sky.",
        "These balloons are red."
      ],
      "commonMistakes": [
        "These is my toys (×) → These are my toys. (✓)",
        "Those are a kite (×) → Those are kites. (✓)"
      ],
      "programLevel": "starters",
      "topic": "toys-and-weather"
    }
  ],
