  "unit": {
    "learningObjectives": [
      "Name common toys and weather words at Starters level.",
      "Use It's + adjective to describe weather: It's sunny.",
      "Form plurals with -s: two kites, three balloons.",
      "Use these and those to point to nearby and distant things.",
      "Describe pictures with toy and weather vocabulary in reading and speaking."
    ],
    "grammarFocus": [
      "It's + weather adjective: It's sunny",
      "Plural nouns: two kites",
      "Demonstratives: these, those"
    ],
    "readingSkillFocus": "Describe Pictures with Weather and Toys",
    "listeningSkillFocus": "Identify Weather and Toy Words"
  },
