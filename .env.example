# Google OAuth (configure in Supabase Dashboard)
# Enable Google provider in Authentication > Providers

# Google Gemini AI (Phase 4)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

