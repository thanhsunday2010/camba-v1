# =============================================================================
# CAMBA - Mẫu biến môi trường
# Copy: cp .env.example .env.local
# =============================================================================

# --- App runtime (BẮT BUỘC) — Supabase Dashboard → Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Liên hệ nổi (Zalo + Messenger) — để trống thì ẩn nút
# Zalo: số điện thoại (vd. 0912345678 hoặc +84912345678)
NEXT_PUBLIC_CONTACT_ZALO=
# Messenger: username Fanpage (vd. camba.edu hoặc m.me/camba.edu)
NEXT_PUBLIC_CONTACT_MESSENGER=
# Hoặc dùng biến server (Vercel → Environment Variables, không cần NEXT_PUBLIC_):
# CONTACT_ZALO=
# CONTACT_MESSENGER=
# Google OAuth on login/register (default: enabled). Set false to hide.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
# OAuth: add matching callback URLs in Supabase Auth → URL Configuration, e.g.
# http://localhost:3000/auth/callback
# http://127.0.0.1:3000/auth/callback
# http://YOUR-LAN-IP:3000/auth/callback

# Content QA: unlock all lessons in the active level (set false for sequential learning)
NEXT_PUBLIC_UNLOCK_ALL_LESSONS=true

# --- Database tools (TÙY CHỌN) — Settings → Database → Direct connection ---
# Chỉ cho migration/CLI, KHÔNG dùng chạy app Next.js
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...supabase.com:5432/postgres

# --- AI chấm Writing/Speaking (BẮT BUỘC cho tính năng AI) ---
# Lấy tại: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# student@camba.me / parent@camba.me / teacher@camba.me / admin@camba.me
# Password: camba123
# Demo/QA: bypass daily AI limits (comma-separated emails, server-only)
# AI_UNLIMITED_USER_EMAILS=student@camba.me

# --- SePay / VietQR (thanh toán gói đăng ký — tiền thật) ---
# TK ngân hàng Live liên kết trên SePay (chế độ Live, không phải Test mode)
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_HOLDER=
SEPAY_PAYMENT_CODE_PREFIX=CAMBA
SEPAY_QR_MEMO_PREFIX=
# API Key từ webhook SePay Live (KHÔNG dùng spsk_test_ trên production)
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_SECRET=
# Bắt buộc true khi nhận chuyển khoản thật
SEPAY_LIVE=true
